# Prediction Market Trading System - Configuration Template
# Copy this file to .env and fill in actual values

# Redis Configuration
REDIS_URL=redis://localhost:6379
SIGNAL_QUEUE_NAME=trading_signals
EVENT_BUS_CHANNEL=market_events

# Database Configuration
DB_PATH=prediction_market.db
DB_POOL_SIZE=5
DB_TIMEOUT=30

# Core Service Configuration
LOG_LEVEL=INFO
INGEST_INTERVAL_S=5
CONSTRAINT_CHECK_INTERVAL_S=10
PNL_SNAPSHOT_INTERVAL_S=300
MODEL_REFIT_INTERVAL_S=3600

# Execution Service Configuration
MAX_ORDER_RETRIES=3
RETRY_BACKOFF_BASE_S=1
ORDER_TIMEOUT_S=30

# Polymarket Configuration
POLYMARKET_RPC_URL=https://polygon-rpc.com
POLYMARKET_CHAIN_ID=137
POLYMARKET_AMM_CONTRACT=0x0000000000000000000000000000000000000000
POLYMARKET_USDC_CONTRACT=0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174
POLYMARKET_PRIVATE_KEY=
POLYMARKET_WALLET_ADDRESS=

# Kalshi Configuration
KALSHI_API_KEY=
KALSHI_API_SECRET=
KALSHI_API_BASE=https://trading-api.kalshi.com/trade-api/v2

# Market Data Configuration
PRICE_FETCH_INTERVAL_S=10
POLYMARKET_API_BASE=https://api.polymarket.com

# EU SOCKS5 proxy for Polymarket (optional — leave blank to connect directly)
# Format: socks5://host:port
POLYMARKET_PROXY=
KALSHI_PUBLIC_API_BASE=https://api.kalshi.com

# Constraint Configuration
MAX_POSITION_SIZE=10000
MAX_DAILY_LOSS=50000
MAX_CONCURRENT_POSITIONS=20
MAX_MARKET_EXPOSURE=5000

# Signal Configuration
SIGNAL_EXPIRY_S=300
ORDER_EXECUTION_MODE=simultaneous
ABORT_ON_PARTIAL=false

# Analytics Configuration
ANALYTICS_OUTPUT_DIR=analytics_export
ENABLE_PNL_TRACKING=true
ENABLE_VIOLATION_LOGGING=true

# Development Configuration
DEBUG=false
ENABLE_MOCK_CLIENTS=false

# Execution Mode: "live" for real trading, "mock" for simulated execution
EXECUTION_MODE=mock

# Feature Flags
ENABLE_AUTO_PAIR_DISCOVERY=true
ENABLE_CONSTRAINT_ENFORCEMENT=true
ENABLE_SIGNAL_GENERATION=true
ENABLE_EXECUTION_SERVICE=true

# Mock Execution Configuration (only used when EXECUTION_MODE=mock)
MOCK_FILL_PROBABILITY=0.95
MOCK_PARTIAL_FILL_PROBABILITY=0.05
MOCK_PARTIAL_FILL_FRACTION=0.6
MOCK_MIN_LATENCY_MS=50
MOCK_MAX_LATENCY_MS=300
MOCK_MIN_FILL_LATENCY_MS=200
MOCK_MAX_FILL_LATENCY_MS=2000
MOCK_MAX_SLIPPAGE=0.01
MOCK_FEE_RATE=0.02
MOCK_VERBOSE=true
