# ── GCP Deployment Configuration ────────────────────────────────────────────
# Copy this file to deploy/config.env and fill in your values.
# deploy/config.env is gitignored — never commit it.

# GCP project ID (must be globally unique; letters, numbers, hyphens only)
PROJECT_ID=predictor-trading-XXXX

# Compute zone — us-central1-a is cheapest
ZONE=us-central1-a

# VM and disk names
VM_NAME=predictor-vm
DATA_DISK_NAME=predictor-data

# Machine type — e2-medium (2 vCPU / 4 GB) is sufficient for paper trading
MACHINE_TYPE=e2-medium

# Set after provision.sh completes (auto-populated)
EXTERNAL_IP=

# ── EU Proxy (set after provision_proxy.sh) ─────────────────────────────────
PROXY_ZONE=europe-west4-a
PROXY_VM=predictor-proxy
PROXY_IP=
PROXY_PORT=1080
